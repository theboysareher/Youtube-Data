MDScreen:
    name: "main"
    Image:
        source: "UI_PICS/Pic_3.jpg"
        allow_stretch: True
        keep_ratio: False   
        size_hint: 1, 1    
        pos_hint: {"center_x": 0.5, "center_y": 0.5}
        
    MDBoxLayout:    
        id: container             
        pos_hint: {"center_x": 0.5, "center_y": 0.45}
        padding : '10dp'
        spacing : '5dp'
        orientation: "vertical"
        md_bg_color: (0/255,0/255,0/255,0.4)
        size_hint: 0.999, 0.93
        opacity: 1
        
        FloatLayout:
            
            MDTextField:
                id: url_field
                icon_left: "link-plus"
                required: True 
                pos_hint: {"center_x": 0.5, "center_y": 0.92}                               
                           
            MDRectangleFlatIconButton:
                text: "Extract Data"
                icon: "magnify"
                line_color: 2, 3, 4, 1
                pos_hint: {"center_x": 0.5, "center_y": 0.83}
                on_release:                 
                    app.downloader(url_field.text)
                    app.clear_field(url_field)
                           
                                          
            MDBoxLayout:
                radius: [95,95,95,95]
                pos_hint: {"center_x": 0.5, "center_y": 0.39}
                md_bg_color: (0/255,0/255,0/255,0.6)
                size_hint: 0.99, 0.75
                
                FloatLayout:
                    
                    MDLabel:
                        id: channel_name
                        text_color: 0, 0, 0, 1
                        text: "[+] channel_name:"
                        pos_hint: {"x": .1, "y": 0.410}
                        
                    MDLabel:
                        id: uploader
                        text_color: 0, 0, 0, 1
                        text: "[+] uploader:"
                        pos_hint: {"x": .1, "y": 0.350}
                        
                    MDLabel:
                        id: channel_is_verified
                        text_color: 0, 0, 0, 1
                        text: "[+] channel_is_verified: "
                        pos_hint: {"x": .1, "y": 0.290}
                        
                    MDLabel:
                        id: viecount
                        text_color: 0, 0, 0, 1
                        text: "[+] viecount:"
                        pos_hint: {"x": .1, "y": 0.230}
                        
                    MDLabel:
                        id: likes
                        text_color: 0, 0, 0, 1
                        text: "[+] likes:"
                        pos_hint: {"x": .1, "y": 0.170}
                        
                    MDLabel:
                        id: duration
                        text_color: 0, 0, 0, 1
                        text: "[+] duration:"
                        pos_hint: {"x": .1, "y": 0.115}
                        
                    MDLabel:
                        id: display_id
                        text_color: 0, 0, 0, 1
                        text: "[+] display_id:"
                        pos_hint: {"x": .1, "y": 0.98}
                        
                    MDLabel:
                        id: upload_date
                        text_color: 0, 0, 0, 1
                        text: "[+] upload_date:"
                        pos_hint: {"x": .1, "y": 0.060}
                        
                    MDLabel:
                        id: channel_follower_count
                        text_color: 0, 0, 0, 1
                        text: "[+] channel_follower_count:"
                        pos_hint: {"x": .1 ,"y": 0.010}
                        
            
                
                                    
                 
                
